# Environment variables template
# Copy this to .env.local for development or to your deployment platform's env vars

# Backend API URL (used by frontend)
VITE_API_URL=http://localhost:8000

# Database URL - defaults to SQLite, but supports PostgreSQL for production
# SQLite (development): sqlite:///./recon.db
# PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./recon.db

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Claude API key (if using invoice PDF extraction)
ANTHROPIC_API_KEY=your_key_here

# App settings
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production
